APP_DB_PATH=app/data/ray_darkauto.db
APP_OUTPUTS_DIR=app/outputs
GOOGLE_CLOUD_PROJECT=seu-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Opcional: caminho do service account JSON (ADC)
# GOOGLE_APPLICATION_CREDENTIALS=C:\caminho\service-account.json
VERTEX_MODEL=gemini-2.5-flash
VERTEX_SCRIPT_MODEL=gemini-2.5-flash
VERTEX_IMAGE_MODEL=gemini-2.5-flash-image
VERTEX_VIDEO_MODEL=veo-3.0-generate-preview
VERTEX_API_VERSION=v1
# Modelos TTS premium habilitados no app:
# - chirp-3.0-generate-001
# - gemini-2.5-flash-tts
# - gemini-2.5-pro-tts
# - gemini-2.5-flash-lite-preview-tts
TTS_MODEL_NAME=chirp-3.0-generate-001
TTS_VOICE_NAME=Achernar
TTS_LANGUAGE_CODE=pt-BR
TTS_AUDIO_FORMAT=wav
TTS_SPEAKING_RATE=1.0
TTS_PITCH=0.0
TTS_VOLUME_GAIN_DB=0.0
TTS_SAMPLE_RATE_HZ=44100
FFMPEG_BIN=ffmpeg
VIDEO_WIDTH=1280
VIDEO_HEIGHT=720
VIDEO_FPS=30
